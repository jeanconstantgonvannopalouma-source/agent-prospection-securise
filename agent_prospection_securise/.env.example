$content = @"
# ===== ENVIRONNEMENT =====
ENV=development

# ===== CLÉS SECRÈTES (À GÉNÉRER!) =====
SECRET_KEY=remplace_par_ta_clé_secrète_générée
ENCRYPTION_KEY=remplace_par_ta_clé_encryptage_générée

# ===== BASE DE DONNÉES =====
# SQLite (développement):
DATABASE_URL=sqlite:///./agent_prospection.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/agent_prospection
DB_TIMEOUT=20

# ===== OPENAI API =====
OPENAI_API_KEY=sk-remplace_par_ta_clé_openai
OPENAI_MODEL=gpt-4
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT=30

# ===== EMAIL SMTP =====
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ton_email@gmail.com
SMTP_PASSWORD=ton_mot_de_passe_app_gmail

# ===== SÉCURITÉ =====
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
JWT_EXPIRY_HOURS=24

# ===== LOGGING =====
LOG_LEVEL=INFO
LOG_FILE=logs\\agent.log
MAX_LOG_SIZE=10485760
BACKUP_COUNT=5

# ===== INPUTS =====
MAX_INPUT_LENGTH=10000

# ===== SENTRY (OPTIONNEL) =====
SENTRY_DSN=

# ===== LINKEDIN (OPTIONNEL) =====
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
LINKEDIN_API_KEY=

# ===== TWILIO (OPTIONNEL) =====
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
"@

$content | Out-File -FilePath ".env.example" -Encoding UTF8 -NoNewline
Write-Host "✓ Fichier créé: .env.example" -ForegroundColor Green